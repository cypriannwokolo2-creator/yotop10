# ─── Frontend ─────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://yotop10.com
NEXT_PUBLIC_API_URL=https://yotop10.com/api
NEXT_PUBLIC_CDN_URL=https://cdn.yotop10.com

# ─── Authentication ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Backend ──────────────────────────────────────────────────────
PORT=8000
JWT_SECRET=your-jwt-secret-key-here
CORS_ORIGINS=https://yotop10.com,https://www.yotop10.com

# ─── MongoDB ──────────────────────────────────────────────────────
MONGODB_USER=yotop10
MONGODB_PASSWORD=your-mongodb-password
MONGODB_URI=mongodb://mongodb:27017/yotop10

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Elasticsearch ────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ─── MinIO (S3 Storage) ─────────────────────────────────────────
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=yotop10
MINIO_SECURE=false

# ─── Email (Brevo) ───────────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@yotop10.com
